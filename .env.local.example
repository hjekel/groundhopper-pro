# ========================================
# Groundhopper Pro - Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values

# Supabase Configuration (REQUIRED)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Groundhopper Pro

# Map Configuration (Optional - defaults to OpenStreetMap)
# For Mapbox (better tiles, requires account)
# NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# External APIs (Optional - for enhanced features)
# Football data - https://www.football-data.org/
# FOOTBALL_DATA_API_KEY=your-api-key

# OpenWeatherMap - https://openweathermap.org/api
# OPENWEATHERMAP_API_KEY=your-api-key

# Vercel-specific (auto-populated on Vercel)
# VERCEL_URL=your-deployment-url
